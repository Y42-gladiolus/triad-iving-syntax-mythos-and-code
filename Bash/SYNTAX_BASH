#!/bin/bash

# lib/functions.sh
log() {
    local LEVEL=$1
    shift
    echo "[$(date +%Y-%m-%d_%H:%M:%S)] [$LEVEL] $*"
}

log_info() {
    log "INFO" "$@"
}

log_error() {
    log "ERROR" "$@" >&2
}

# Использование
#!/bin/bash
source lib/functions.sh
log_info "Script started"
