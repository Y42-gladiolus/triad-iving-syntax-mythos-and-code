#!/bin/bash

# Комментарии (решётка)
# Однострочные

# Echo (вывод)
echo "Hello, Bash!"
echo "Variable: $VAR"
echo -n "No newline"  # Без newline
echo -e "Tab:\tSpace" # С escape

# Чтение ввода
read -p "Enter name: " NAME
echo "Hello, $NAME"

# read с опциями
read -s PASSWORD  # Silent (password)
read -t 5 INPUT   # Timeout 5 seconds
read -a ARRAY     # Read into array

# Точка с запятой (разделитель команд)
echo "First"; echo "Second"

# Обратный слэш (продолжение строки)
echo "This is a very long \
line that continues"

# Цитирование
echo "Hello $NAME"      # Интерполяция
echo 'Hello $NAME'      # Без интерполяции
echo "Hello \"World\""  # Экранирование
echo $'Hello\nWorld'    # ANSI-C quoting

================================================================================
2. ПЕРЕМЕННЫЕ
================================================================================

# Объявление переменных
NAME="John"
AGE=25
PI=3.14

# Использование переменных
echo $NAME
echo ${NAME}
echo "${NAME} is ${AGE}"

# Переменные окружения
export PATH="/usr/local/bin:$PATH"
export HOME="/home/user"

# Local переменные (в функциях)
my_function() {
    local VAR="local value"
}

# Readonly переменные
readonly PI=3.14
PI=3.15  # ОШИБКА!

# Unset переменных
unset VAR
unset -f function_name  # Удалить функцию

# Default values
echo ${VAR:-default}    # default если VAR не установлен
echo ${VAR:=default}    # Установить default если не установлен
echo ${VAR:+value}      # value если VAR установлен
echo ${VAR:?error}      # error если VAR не установлен

# Parameter expansion
${VAR}          # Значение
${VAR:-default} # Default если пустой
${VAR:=default} # Assign default
${VAR:+value}   # Value если установлен
${VAR:?error}   # Error если пустой
${#VAR}         # Длина
${VAR:0:5}      # Substring
${VAR/pattern/replacement}  # Замена

================================================================================
3. АРИФМЕТИКА
================================================================================

# Арифметика ($(( )))
echo $((2 + 2))      # 4
echo $((10 - 3))     # 7
echo $((5 * 3))      # 15
echo $((10 / 2))     # 5
echo $((10 % 3))     # 1
echo $((2 ** 3))     # 8 (exponent)

# Переменные в арифметике
A=5
B=10
echo $((A + B))      # 15

# Инкремент/декремент
((A++))
((B--))
((++A))
((--B))

# Сравнения
echo $((5 > 3))      # 1 (true)
echo $((5 < 3))      # 0 (false)
echo $((5 == 5))     # 1 (true)
echo $((5 != 3))     # 1 (true)
echo $((5 >= 5))     # 1 (true)
echo $((5 <= 3))     # 0 (false)

# let команда
let A=5
let B=A+3
echo $B              # 8

# declare -i (integer variable)
declare -i NUM=5
NUM=NUM+1
echo $NUM            # 6

# bc (arbitrary precision)
echo "scale=2; 10/3" | bc  # 3.33

================================================================================
4. CONTROL FLOW
================================================================================

# If/elif/else
if [ $A -gt $B ]; then
    echo "A greater"
elif [ $A -eq $B ]; then
    echo "Equal"
else
    echo "B greater"
fi

# Test команды ([ ])
[ -f file.txt ]      # File exists
[ -d dir ]           # Directory exists
[ -r file ]          # Readable
[ -w file ]          # Writable
[ -x file ]          # Executable
[ -z "$VAR" ]        # Empty string
[ -n "$VAR" ]        # Non-empty string
[ "$A" = "$B" ]      # String equal
[ "$A" != "$B" ]     # String not equal

# Test команды ([[ ]] - bash extension)
[[ $A > $B ]]        # String comparison
[[ $A -gt $B ]]      # Numeric comparison
[[ -f file && -r file ]]  # AND
[[ -f file || -d file ]]  # OR
[[ ! -f file ]]      # NOT

# Case (switch)
case $VAR in
    start|run)
        echo "Starting"
        ;;
    stop|quit)
        echo "Stopping"
        ;;
    restart)
        echo "Restarting"
        ;;
    *)
        echo "Unknown"
        ;;
esac

# For цикл
for i in 1 2 3 4 5; do
    echo $i
done

# For с range
for i in {1..10}; do
    echo $i
done

# For с step
for i in {1..10..2}; do
    echo $i
done

# For over files
for file in *.txt; do
    echo $file
done

# For C-style
for ((i=0; i<10; i++)); do
    echo $i
done

# While цикл
COUNT=0
while [ $COUNT -lt 10 ]; do
    echo $COUNT
    ((COUNT++))
done

# Read in while
while IFS= read -r line; do
    echo "$line"
done < file.txt

# Until цикл (отрицание while)
COUNT=0
until [ $COUNT -ge 10 ]; do
    echo $COUNT
    ((COUNT++))
done

# Break/Continue
for i in {1..10}; do
    if [ $i -eq 5 ]; then
        continue
    fi
    if [ $i -eq 8 ]; then
        break
    fi
    echo $i
done

# Select (menu)
select OPTION in "Option 1" "Option 2" "Option 3"; do
    case $OPTION in
        "Option 1") echo "Selected 1"; break ;;
        "Option 2") echo "Selected 2"; break ;;
        "Option 3") echo "Selected 3"; break ;;
    esac
done

