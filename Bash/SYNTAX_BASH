# Объявление функции
my_function() {
    echo "Hello from function"
}

# Или
function my_function {
    echo "Hello from function"
}

# Функция с аргументами
greet() {
    local NAME=$1
    local AGE=$2
    echo "Hello, $NAME. You are $AGE years old."
}

# Вызов функции
my_function
greet "John" 25

# Аргументы функции
$0      # Имя функции
$1      # Первый аргумент
$2      # Второй аргумент
$#      # Количество аргументов
$@      # Все аргументы (отдельно)
$*      # Все аргументы (одно слово)
${10}   # Десятый аргумент (нужны скобки)

# Return value
add() {
    local A=$1
    local B=$2
    return $((A + B))
}

add 5 3
echo $?  # 8 (exit code, только 0-255)

# Return через echo
add() {
    local A=$1
    local B=$2
    echo $((A + B))
}

RESULT=$(add 5 3)
echo $RESULT  # 8

# Local переменные
my_function() {
    local VAR="local value"
    echo $VAR
}

# Global переменные
GLOBAL="global value"
my_function() {
    GLOBAL="changed"
}

# Recursive функции
factorial() {
    local N=$1
    if [ $N -le 1 ]; then
        echo 1
    else
        echo $((N * $(factorial $((N-1)))))
    fi
}

================================================================================
6. ARRAYS (INDEXED + ASSOCIATIVE)
================================================================================

# Indexed arrays
ARRAY=(one two three four five)

# Доступ к элементам
echo ${ARRAY[0]}      # one
echo ${ARRAY[1]}      # two
echo ${ARRAY[-1]}     # five (последний, bash 4.3+)

# Длина массива
echo ${#ARRAY[@]}     # 5

# Все элементы
echo ${ARRAY[@]}      # one two three four five
echo ${ARRAY[*]}      # one two three four five

# Срез массива
echo ${ARRAY[@]:1:3}  # two three four

# Добавление элемента
ARRAY+=(six seven)

# Удаление элемента
unset ARRAY[2]

# Итерация по массиву
for item in "${ARRAY[@]}"; do
    echo $item
done

# Indexed array с declare
declare -a NUMS
NUMS=(1 2 3 4 5)

# Associative arrays (bash 4+)
declare -A ASSOC
ASSOC[name]="John"
ASSOC[age]=25
ASSOC[city]="Moscow"

# Доступ
echo ${ASSOC[name]}   # John
echo ${ASSOC[age]}    # 25

# Все ключи
echo ${!ASSOC[@]}     # name age city

# Все значения
echo ${ASSOC[@]}      # John 25 Moscow

# Длина
echo ${#ASSOC[@]}     # 3

# Итерация
for key in "${!ASSOC[@]}"; do
    echo "$key: ${ASSOC[$key]}"
done

