echo $DATE

# ` ` синтаксис (устаревший)
DATE=`date`
echo $DATE

# Вложенная подстановка
echo $(echo $(echo "nested"))

# Command substitution с арифметикой
COUNT=$(wc -l < file.txt)
echo "Lines: $COUNT"

# Process substitution
diff <(sort file1) <(sort file2)
