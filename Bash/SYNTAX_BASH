7. STRING OPERATIONS
================================================================================

VAR="Hello World"

# Длина строки
echo ${#VAR}          # 11

# Substring
echo ${VAR:0:5}       # Hello
echo ${VAR:6}         # World

# Замена
echo ${VAR/World/Unix}    # Hello Unix
echo ${VAR//l/L}          # HeLLo WorLd (все)
echo ${VAR/#Hello/Hi}     # Hi World (начало)
echo ${VAR/%World/Unix}   # Hello Unix (конец)

# Удаление
echo ${VAR/World/}        # Hello 
echo ${VAR// /}           # HelloWorld (удалить пробелы)

# Trim whitespace
VAR="  hello  "
echo "${VAR#" "}";        # "hello  " (left trim)
echo "${VAR%" "}";        # "  hello" (right trim)
echo "${VAR## }";         # "hello  " (left trim all)
echo "${VAR%% }";         # "  hello" (right trim all)

# Upper/Lower case (bash 4+)
VAR="Hello"
echo ${VAR^^}             # HELLO (upper)
echo ${VAR,,}             # hello (lower)
echo ${VAR^}              # Hello (first upper)
echo ${VAR,}              # hello (first lower)

# Pattern matching
VAR="file.txt"
echo ${VAR%.txt}          # file (удалить суффикс)
echo ${VAR%%.*}           # file (удалить всё после точки)
echo ${VAR#file.}         # txt (удалить префикс)
echo ${VAR##*.}           # txt (удалить всё до точки)

# Проверка паттерна
[[ $VAR == *.txt ]] && echo "Text file"

================================================================================
8. FILE I/O
================================================================================

# Чтение файла
while IFS= read -r line; do
    echo "$line"
done < file.txt

# Запись в файл
echo "Hello" > file.txt      # Перезаписать
echo "World" >> file.txt     # Добавить

# Чтение в массив
mapfile -t LINES < file.txt  # Bash 4+
# Или
readarray -t LINES < file.txt

# Итерация по массиву из файла
for line in "${LINES[@]}"; do
    echo "$line"
done

# Redirect stdout/stderr
command > output.txt         # stdout
command 2> error.txt         # stderr
command > output.txt 2>&1    # оба
command &> output.txt        # оба (bash 4+)
command >> output.txt        # append

# Here document
cat << EOF
Hello
World
EOF

# Here document с переменной
cat << EOF
Hello $NAME
EOF

# Here document без интерполяции
cat << 'EOF'
Hello $NAME  # Без интерполяции
EOF

# Here string
read VAR <<< "Hello World"
echo $VAR

# File descriptors
exec 3> file.txt
echo "Hello" >&3
exec 3>&-

# Save/restore stdout
exec 3>&1
echo "Hello" >&3
exec 3>&-

