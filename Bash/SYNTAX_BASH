10. ТИПИЧНЫЕ ОШИБКИ (РАСШИРЕНО!)
================================================================================

❌ Ошибка 1: Пробелы в присваивании
VAR = "value"  # ОШИБКА! Пробелы не допускаются

✓ Решение:
VAR="value"  # OK

❌ Ошибка 2: Неправильное цитирование
echo $VAR  # Может разбиться на слова

✓ Решение:
echo "$VAR"  # Всегда цитировать!

❌ Ошибка 3: Неправильный test
if [ $VAR = "value" ]  # ОШИБКА если VAR пустой!

✓ Решение:
if [ "$VAR" = "value" ]  # Цитировать!

❌ Ошибка 4: Арифметика без $(( ))
VAR=5
VAR=$VAR+1  # ОШИБКА! Строка "5+1"

✓ Решение:
VAR=$((VAR + 1))  # OK

❌ Ошибка 5: Forgetting to quote in for loop
for i in $VAR; do  # ОШИБКА если VAR содержит пробелы!

✓ Решение:
for i in "$VAR"; do  # OK

❌ Ошибка 6: Using == in [ ]
if [ $A == $B ]  # Работает в bash, не в sh!

✓ Решение:
if [ $A = $B ]  # POSIX совместимо
или
if [[ $A == $B ]]  # bash extension

❌ Ошибка 7: Not checking exit codes
command
# Игнорируется ошибка!

✓ Решение:
command || exit 1
# Или:
if ! command; then
    exit 1
fi

❌ Ошибка 8: Using rm -rf без проверки
rm -rf $VAR/*  # ОПАСНО если VAR пустой!

✓ Решение:
if [ -n "$VAR" ]; then
    rm -rf "$VAR"/*
fi

❌ Ошибка 9: Not using local in functions
my_function() {
    VAR="value"  # Глобальная переменная!
}

✓ Решение:
my_function() {
    local VAR="value"  # Локальная
}

❌ Ошибка 10: Forgetting shebang
# Скрипт без shebang
echo "Hello"

✓ Решение:
#!/bin/bash
echo "Hello"

❌ Ошибка 11: Using $() в [ ]
if [ $(command) = "value" ]  # Может не работать!

✓ Решение:
if [[ $(command) = "value" ]]  # bash extension

❌ Ошибка 12: Not escaping in case
case $VAR in
    *.txt)  # ОШИБКА! Нужно экранировать
        echo "Text file"
        ;;
esac

✓ Решение:
case $VAR in
    *.txt)  # OK в case не нужно экранировать
        echo "Text file"
        ;;
esac

