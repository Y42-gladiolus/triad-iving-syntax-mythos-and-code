Пример 5: Health check
----------------------
#!/bin/bash
set -euo pipefail

check_disk() {
    local USAGE
    USAGE=$(df / | tail -1 | awk '{print $5}' | tr -d '%')
    if [ "$USAGE" -gt 90 ]; then
        echo "WARNING: Disk usage at ${USAGE}%"
        return 1
    fi
    return 0
}

check_disk || exit 1
echo "Health check passed"

